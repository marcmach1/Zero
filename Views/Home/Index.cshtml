@{
    ViewData["Title"] = "Home Page";
}

<div class="text-center">
    <h1 class="display-4">Welcome</h1>
    <p>Learn about <a href="https://learn.microsoft.com/aspnet/core">building Web apps with ASP.NET Core</a>.</p>
</div>


<div class="text-center mt-5">
    <h2 class="display-4">E aí, vai cair? 🌊</h2>
    <p>Clique no botão abaixo para o Zero analisar as condições aí onde você está.</p>
    
    <button onclick="buscarBoletimLocal()" class="btn btn-primary btn-lg shadow">
        <i class="fas fa-map-marker-alt"></i> Ver Maré Local
    </button>

    <div id="loader" class="mt-3" style="display:none;">
        <div class="spinner-border text-info" role="status"></div>
        <p class="text-info">Zero está remando para o outside... peraí!</p>
    </div>
</div>


<script>
    function buscarBoletimLocal() {
        // Mostra o loader e esconde o botão
        document.getElementById('loader').style.display = 'block';

        if (navigator.geolocation) {
            navigator.geolocation.getCurrentPosition(
                (position) => {
                    const lat = position.coords.latitude;
                    const lon = position.coords.longitude;

                    // Redireciona para a rota do Controller com as coordenadas
                    window.location.href = `/zero/boletim-local?lat=${lat}&lon=${lon}`;
                },
                (error) => {
                    alert("Putz! Preciso da localização para saber o pico. Verifique as permissões do navegador.");
                    document.getElementById('loader').style.display = 'none';
                }
            );
        } else {
            alert("Seu navegador não suporta geolocalização.");
            document.getElementById('loader').style.display = 'none';
        }
    }
</script>